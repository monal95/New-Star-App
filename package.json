{
  "name": "tailoring-app",
  "version": "1.0.0",
  "description": "Smart Tailoring Management System - Desktop Application",
  "main": "main.js",
  "homepage": "./",
  "author": "Monal Prahanth C",
  "license": "MIT",
  "scripts": {
    "start": "npm run build:frontend && electron .",
    "dev": "electron .",
    "build": "npm run build:frontend && npm run pack",
    "build:frontend": "echo \"Building frontend...\" && cd frontend && npm install && npm run build && cd ..",
    "pack": "electron-packager . TailoringApp --platform=win32 --arch=x64 --out=releases --overwrite",
    "pack-all": "npm run build",
    "rebuild-native": "electron-rebuild"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-installer-windows": "^3.0.0",
    "electron-packager": "^17.1.1",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "appId": "com.tailoringapp",
    "productName": "Smart Tailoring Management System"
  }
}
